{
  "name": "esuhai-bookcarmobile",
  "version": "3.7.3",
  "private": true,
  "homepage": ".",
  "dependencies": {
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.7.7",
    "date-fns": "^4.1.0",
    "i18next": "^21.6.0",
    "react": "^18.3.1",
    "react-datepicker": "^7.5.0",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.5",
    "react-google-charts": "^5.2.1",
    "react-i18next": "^11.15.3",
    "react-icons": "^5.3.0",
    "react-router-dom": "^6.28.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "npm run version-bump && dotenv -e .env react-scripts build",
    "version-bump": "node version-bump.js",
    "postbuild": "node postbuild.js",
    "deploy": "dotenv -e .env -- bash -c 'curl -X POST $REACT_APP_DEPLOY_URL -F \"path=bookcarmobile\" -F \"secret=$DAT_PHONG_KEY_DEPLOY\" -F \"file=@deploy/build.zip\"'",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^7.4.2",
    "postcss": "^8.5.1",
    "postcss-cli": "^11.0.0",
    "postcss-loader": "^8.1.1",
    "postcss-scss": "^4.0.9",
    "rimraf": "^6.0.1",
    "sass": "^1.84.0",
    "tailwindcss": "^3.4.17",
    "zip-cli": "^0.0.0"
  }
}
